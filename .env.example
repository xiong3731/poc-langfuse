# Langfuse 自托管实例（与 docker-compose.yml 中的 INIT 值一致）
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-0000000000000000
LANGFUSE_SECRET_KEY=sk-lf-0000000000000000

# LLM（OpenAI 兼容接口）
OPENAI_BASE_URL=https://api.modelverse.cn/v1
OPENAI_API_KEY=替换成你的key
LLM_MODEL=glm-5.1

# K8s MCP server 镜像
MCP_IMAGE=ghcr.io/containers/kubernetes-mcp-server:v0.0.63

# kubeconfig 路径，留空则使用 ~/.kube/config
KUBECONFIG=

# Agent 任务（可选，留空使用默认任务）
TASK=列出集群里所有的 namespace，并简要说明每个 namespace 大致是做什么用的

# Agent 最大循环轮数（防止失控）
MAX_TURNS=10
